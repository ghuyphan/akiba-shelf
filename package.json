{
  "name": "akiba-shelf",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "vendor/gacha-simulator",
    "vendor/hsr-simulator"
  ],
  "scripts": {
    "dev": "node scripts/build-simulator-dev.mjs genshin --if-missing && node scripts/build-simulator-dev.mjs hsr --if-missing && vite --host ::",
    "build:gacha:dev": "node scripts/build-simulator-dev.mjs genshin",
    "build:hsr:dev": "node scripts/build-simulator-dev.mjs hsr",
    "build:simulators": "node scripts/build-simulators.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint --max-warnings 0 src e2e vite.config.ts vitest.config.ts playwright.config.ts playwright.perf.config.ts",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write package.json wrangler.jsonc eslint.config.js playwright.config.ts playwright.perf.config.ts vitest.config.ts",
    "format:check": "prettier --check package.json wrangler.jsonc eslint.config.js playwright.config.ts playwright.perf.config.ts vitest.config.ts e2e/admin-auth.spec.ts .github/workflows",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "node vendor/gacha-simulator/scripts/xss-regression.mjs && node vendor/hsr-simulator/scripts/xss-regression.mjs",
    "test:simulators": "node vendor/shared/gacha-policy.test.mjs",
    "test:e2e": "playwright test",
    "test:perf": "playwright test --config playwright.perf.config.ts",
    "test:db": "supabase test db",
    "test:functions": "deno test --node-modules-dir=none --no-lock --allow-env supabase/functions/create-order/index.test.ts supabase/functions/invite-shop-member/index.test.ts supabase/functions/notify-new-order/index.test.ts supabase/functions/gacha-music-proxy/index.test.ts",
    "test:db:integration": "vitest run src/test/database.integration.test.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run test:security && npm run test:simulators && npm run build",
    "build:app": "tsc -b && vite build",
    "build:perf": "tsc -b && vite build --outDir .perf-dist",
    "build": "npm run build:app && npm run build:simulators && node scripts/build-offline-assets.mjs",
    "deploy:cloudflare": "wrangler pages deploy dist --project-name=matsuri --branch=main",
    "preview:cloudflare": "wrangler pages dev dist",
    "preview": "vite preview --host ::",
    "preview:perf": "vite preview --host 127.0.0.1 --outDir .perf-dist --port 4174 --strictPort"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zod": "4.4.3"
  },
  "overrides": {
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.55.1",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.46.4",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "3.2.4",
    "wrangler": "4.113.0"
  }
}
