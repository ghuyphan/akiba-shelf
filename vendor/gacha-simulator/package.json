{
	"name": "matsuri-wish-simulator",
	"private": true,
	"description": "Realistic Genshin Impact Wish Simulator, Unlimited Gacha, 100% running on browser",
	"version": "2.0.0",
	"author": {
		"name": "jaihysc",
		"email": "jaihysc@gmail.com",
		"url": "https://github.com/jaihysc"
	},
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && mkdir -p .svelte-kit/output/server && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write ."
	},
	"type": "module",
	"devDependencies": {
		"@sveltejs/adapter-static": "1.0.6",
		"@sveltejs/kit": "1.30.4",
		"autoprefixer": "^10.4.8",
		"dotenv": "^16.0.0",
		"eslint": "^8.16.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-svelte3": "^4.0.0",
		"postcss": "^8.4.16",
		"postcss-load-config": "^4.0.1",
		"postcss-nested": "^5.0.6",
		"prettier": "^2.6.2",
		"prettier-plugin-svelte": "^2.7.0",
		"svelte": "3.59.2",
		"svelte-check": "^2.9.2",
		"svelte-preprocess": "^4.10.6",
		"uuid": "^9.0.0",
		"vite": "4.5.14",
		"vite-plugin-markdown": "^2.1.0"
	},
	"dependencies": {
		"file-saver": "^2.0.5",
		"howler": "^2.2.3",
		"html-to-image": "^1.8.5",
		"idb": "^6.1.2",
		"overlayscrollbars": "^1.13.1",
		"svelte-i18n": "^3.4.0"
	}
}
