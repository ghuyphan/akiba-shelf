VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_TURNSTILE_SITE_KEY=
VITE_VAPID_PUBLIC_KEY=
# Required only for web push. There is deliberately no built-in fallback key.
VITE_SENTRY_DSN=
# Public release environment label used by browser error and RUM events.
VITE_APP_ENV=development
# Fraction from 0 to 1. RUM is sent only when VITE_SENTRY_DSN is configured.
VITE_RUM_SAMPLE_RATE=0.1
